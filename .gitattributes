# ============================================================
# General text handling
# ============================================================

# Let Git automatically detect text files and normalize line endings.
# Text files are stored as LF in the repository.
* text=auto

# ============================================================
# Source code - force LF
# ============================================================

*.py      text eol=lf
*.pyi     text eol=lf
*.ipynb   text eol=lf

*.js      text eol=lf
*.jsx     text eol=lf
*.ts      text eol=lf
*.tsx     text eol=lf
*.vue     text eol=lf

*.java    text eol=lf
*.go      text eol=lf
*.rs      text eol=lf
*.c       text eol=lf
*.h       text eol=lf
*.cpp     text eol=lf
*.hpp     text eol=lf

# ============================================================
# Config files - force LF
# ============================================================

*.toml    text eol=lf
*.ini     text eol=lf
*.cfg     text eol=lf
*.conf    text eol=lf
*.json    text eol=lf
*.jsonl   text eol=lf
*.yaml    text eol=lf
*.yml     text eol=lf
*.xml     text eol=lf
*.env     text eol=lf
*.env.*   text eol=lf

.editorconfig  text eol=lf
.gitignore     text eol=lf
.gitattributes text eol=lf
*.gitignore    text eol=lf
*.gitattributes text eol=lf

# ============================================================
# Docker / deployment files - force LF
# ============================================================

Dockerfile        text eol=lf
Dockerfile.*      text eol=lf
*.dockerfile      text eol=lf
docker-compose.yml  text eol=lf
docker-compose.yaml text eol=lf

*.service text eol=lf
*.timer   text eol=lf

# ============================================================
# Shell scripts - force LF
# Very important for Linux execution
# ============================================================

*.sh      text eol=lf
*.bash    text eol=lf
*.zsh     text eol=lf
*.fish    text eol=lf
mvnw      text eol=lf

# ============================================================
# Windows scripts - force CRLF
# ============================================================

*.bat     text eol=crlf
*.cmd     text eol=crlf
*.ps1     text eol=crlf

# ============================================================
# Documentation - force LF
# ============================================================

*.md      text eol=lf
*.rst     text eol=lf
*.txt     text eol=lf
*.csv     text eol=lf
*.tsv     text eol=lf

LICENSE   text eol=lf
README    text eol=lf
README.*  text eol=lf

# ============================================================
# Python package / dependency files
# ============================================================

requirements*.txt text eol=lf
constraints*.txt  text eol=lf
pyproject.toml    text eol=lf
setup.py          text eol=lf
setup.cfg         text eol=lf
MANIFEST.in       text eol=lf
Pipfile           text eol=lf
Pipfile.lock      text eol=lf
poetry.lock       text eol=lf
uv.lock           text eol=lf

# ============================================================
# SQL / migration files
# ============================================================

*.sql     text eol=lf

# ============================================================
# Binary files
# ============================================================

*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.webp    binary
*.ico     binary
*.bmp     binary
*.tiff    binary
*.svg     text eol=lf

*.pdf     binary
*.doc     binary
*.docx    binary
*.xls     binary
*.xlsx    binary
*.ppt     binary
*.pptx    binary

*.zip     binary
*.tar     binary
*.gz      binary
*.tgz     binary
*.bz2     binary
*.xz      binary
*.7z      binary
*.rar     binary

*.mp3     binary
*.wav     binary
*.flac    binary
*.aac     binary
*.ogg     binary
*.mp4     binary
*.mov     binary
*.avi     binary
*.mkv     binary

*.ttf     binary
*.otf     binary
*.woff    binary
*.woff2   binary

# ============================================================
# ML / AI model and data files
# ============================================================

*.pt          binary
*.pth         binary
*.ckpt        binary
*.bin         binary
*.onnx        binary
*.safetensors binary
*.gguf        binary
*.ggml        binary
*.tflite      binary
*.pb          binary
*.pkl         binary
*.pickle      binary
*.joblib      binary
*.npy         binary
*.npz         binary
*.parquet     binary
*.arrow       binary
*.feather     binary
*.h5          binary
*.hdf5        binary

